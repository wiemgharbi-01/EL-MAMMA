@startuml
header Projet El-MAMMA - Groupe A08
title Diagramme de Cas d'Utilisation Global

left to right direction

actor "Étudiant" as E
actor "Cuisinière / Personnel" as C

rectangle "Système El-MAMMA" {
    usecase "Consulter le catalogue" as UC1
    usecase "Réserver un plat" as UC2
    usecase "Gérer son portefeuille" as UC3
    usecase "Recevoir remise éco-consigne" as UC4
    usecase "Valider une commande" as UC5
    usecase "Modifier statut commande" as UC6
    usecase "Consulter historique transactions" as UC7
}

E --> UC1
E --> UC2
E --> UC3
E --> UC7
UC2 ..> UC1 : <<extend>>
UC2 ..> UC4 : <<include>>
UC2 ..> UC3 : <<include>>

C --> UC5
C --> UC6
C --> UC1
@enduml